<!DOCTYPE html>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400&family=Montserrat:wght@200;300;400&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{--ink:#080808;--paper:#f5f2ec;--gold:#c8a96e;--muted:#7a7060;--ease:cubic-bezier(.25,.1,.25,1);--spring:cubic-bezier(.34,1.56,.64,1)}
body{background:var(--ink);color:var(--paper);font-family:'Montserrat',sans-serif;font-weight:300;min-height:100vh;overflow-x:hidden}

.header{text-align:center;padding:3rem 2rem 1.5rem;position:relative}
.header::after{content:'';display:block;width:44px;height:1px;background:var(--gold);margin:1.5rem auto 0}
.eyebrow{font-size:9px;letter-spacing:.4em;color:var(--gold);text-transform:uppercase;margin-bottom:1rem}
.htitle{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:300;letter-spacing:.05em;line-height:1.1}
.htitle em{font-style:italic;color:var(--gold)}

.filter-bar{display:flex;justify-content:center;gap:2.5rem;padding:2rem 1rem 2.5rem;flex-wrap:wrap}
.fbtn{background:none;border:none;color:var(--muted);font-family:'Montserrat',sans-serif;font-size:9px;letter-spacing:.3em;text-transform:uppercase;cursor:pointer;padding:.4rem 0;position:relative;transition:color .3s}
.fbtn::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--gold);transition:width .3s var(--ease)}
.fbtn:hover,.fbtn.active{color:var(--paper)}
.fbtn.active::after{width:100%}

.gallery{max-width:1100px;margin:0 auto;padding:0 1.5rem 5rem;columns:3 260px;gap:14px}

.card{break-inside:avoid;margin-bottom:14px;position:relative;cursor:pointer;overflow:hidden;border-radius:2px;opacity:0;transform:translateY(20px);transition:opacity .6s var(--ease),transform .6s var(--ease)}
.card.visible{opacity:1;transform:translateY(0)}
.card-img{width:100%;display:block;transition:transform .7s var(--ease)}
.card:hover .card-img{transform:scale(1.05)}

.card-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,.88) 0%,rgba(8,8,8,.1) 50%,transparent 100%);opacity:0;transition:opacity .4s;display:flex;flex-direction:column;justify-content:flex-end;padding:1.1rem}
.card:hover .card-overlay{opacity:1}
.card-title{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:300;transform:translateY(8px);transition:transform .35s var(--ease) .05s}
.card:hover .card-title{transform:translateY(0)}
.card-meta{font-size:8px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-top:.3rem;transform:translateY(8px);transition:transform .35s var(--ease) .1s}
.card:hover .card-meta{transform:translateY(0)}
.expand-ic{position:absolute;top:.8rem;right:.8rem;width:26px;height:26px;border:1px solid rgba(245,242,236,.45);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transform:scale(.6);transition:opacity .3s,transform .3s var(--spring)}
.card:hover .expand-ic{opacity:1;transform:scale(1)}
.expand-ic svg{width:9px;height:9px;fill:var(--paper)}

/* loading shimmer */
.card-img.loading{background:linear-gradient(90deg,#1a1a1a 25%,#2a2a2a 50%,#1a1a1a 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;min-height:200px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* ── Lightbox ── */
#lb{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;pointer-events:none;opacity:0;transition:opacity .4s var(--ease)}
#lb.open{opacity:1;pointer-events:all}
.lb-back{position:absolute;inset:0;background:rgba(4,4,4,.97);cursor:pointer}
.lb-stage{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;max-width:90vw;max-height:92vh;transform:scale(.92) translateY(18px);transition:transform .45s var(--spring)}
#lb.open .lb-stage{transform:scale(1) translateY(0)}
.lb-img-wrap{position:relative;overflow:hidden;border-radius:2px;box-shadow:0 40px 100px rgba(0,0,0,.75)}
#lb-img{display:block;max-width:82vw;max-height:72vh;object-fit:contain;transition:opacity .3s,transform .3s}
.lb-strip{display:flex;gap:6px;margin-top:14px;overflow-x:auto;scrollbar-width:none;padding:3px 0;max-width:82vw}
.lb-strip::-webkit-scrollbar{display:none}
.lb-th{width:54px;height:36px;object-fit:cover;border-radius:1px;opacity:.4;cursor:pointer;transition:opacity .2s,border-color .2s;flex-shrink:0;border:1px solid transparent}
.lb-th.active,.lb-th:hover{opacity:1;border-color:var(--gold)}
.lb-cap{text-align:center;margin-top:12px}
.lb-ctitle{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:300;letter-spacing:.05em}
.lb-cmeta{font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);margin-top:.35rem}
.lb-arr{position:fixed;top:50%;transform:translateY(-50%);background:none;border:1px solid rgba(245,242,236,.2);color:var(--paper);width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.9rem;transition:background .2s,border-color .2s;z-index:2}
.lb-arr:hover{background:rgba(200,169,110,.15);border-color:var(--gold)}
#lb-prev{left:1.2rem}
#lb-next{right:1.2rem}
#lb-close{position:fixed;top:1.1rem;right:1.3rem;background:none;border:1px solid rgba(245,242,236,.2);color:var(--paper);width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.7rem;transition:background .2s,border-color .2s;z-index:2}
#lb-close:hover{background:rgba(200,169,110,.15);border-color:var(--gold)}
#lb-count{position:fixed;top:1.4rem;left:50%;transform:translateX(-50%);font-size:9px;letter-spacing:.3em;color:var(--muted);z-index:2}
.lb-hint{position:fixed;bottom:1rem;left:50%;transform:translateX(-50%);font-size:8px;letter-spacing:.25em;color:rgba(122,112,96,.45);z-index:2;white-space:nowrap}

.footer{text-align:center;padding:1.5rem;font-size:9px;letter-spacing:.28em;color:rgba(122,112,96,.4);text-transform:uppercase;border-top:1px solid rgba(245,242,236,.06);margin-top:1rem}
kbd{font-family:inherit;border:1px solid rgba(245,242,236,.18);padding:0 4px;border-radius:2px}
@media(max-width:560px){.gallery{columns:2 130px}.lb-arr{display:none}}
</style>

<div class="header">
  <div class="eyebrow">Portfolio · 2024</div>
  <h1 class="htitle">Through the<br><em>Lens</em></h1>
</div>

<div class="filter-bar">
  <button class="fbtn active" data-f="all">All</button>
  <button class="fbtn" data-f="landscape">Landscape</button>
  <button class="fbtn" data-f="portrait">Portrait</button>
  <button class="fbtn" data-f="urban">Urban</button>
</div>

<div class="gallery" id="gal"></div>

<div class="footer">© 2024 &nbsp;·&nbsp; All rights reserved &nbsp;·&nbsp; <kbd>←→</kbd> navigate &nbsp;·&nbsp; <kbd>ESC</kbd> close</div>

<div id="lb">
  <div class="lb-back" id="lb-back"></div>
  <div class="lb-stage">
    <div class="lb-img-wrap">
      <img id="lb-img" src="" alt="">
    </div>
    <div class="lb-strip" id="lb-strip"></div>
    <div class="lb-cap">
      <div class="lb-ctitle" id="lb-ctitle"></div>
      <div class="lb-cmeta" id="lb-cmeta"></div>
    </div>
  </div>
  <button class="lb-arr" id="lb-prev">&#8592;</button>
  <button class="lb-arr" id="lb-next">&#8594;</button>
  <button id="lb-close">✕</button>
  <div id="lb-count"></div>
  <div class="lb-hint">← → navigate &nbsp;·&nbsp; ESC close</div>
</div>

<script>
const photos = [
  {
    src:'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&q=80',
    title:'Alpine Solitude', meta:'Landscape · f/8 · 1/250s · ISO 100', cat:'landscape', aspectH:66
  },
  {
    src:'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=600&q=80',
    title:'Golden Hour', meta:'Portrait · f/1.8 · 1/1000s · ISO 200', cat:'portrait', aspectH:120
  },
  {
    src:'https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=600&q=80',
    title:'City at Dusk', meta:'Urban · f/11 · 2s · ISO 800', cat:'urban', aspectH:75
  },
  {
    src:'https://images.unsplash.com/photo-1448375240586-882707db888b?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1448375240586-882707db888b?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1448375240586-882707db888b?w=600&q=80',
    title:'Morning Mist', meta:'Landscape · f/16 · 1/60s · ISO 64', cat:'landscape', aspectH:65
  },
  {
    src:'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=600&q=80',
    title:'Quiet Gaze', meta:'Portrait · f/2.8 · 1/500s · ISO 400', cat:'portrait', aspectH:125
  },
  {
    src:'https://images.unsplash.com/photo-1519608487953-e999c86e7455?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1519608487953-e999c86e7455?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1519608487953-e999c86e7455?w=600&q=80',
    title:'Neon Streets', meta:'Urban · f/5.6 · 1/30s · ISO 3200', cat:'urban', aspectH:67
  },
  {
    src:'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=600&q=80',
    title:'Emerald Valley', meta:'Landscape · f/11 · 1/125s · ISO 100', cat:'landscape', aspectH:67
  },
  {
    src:'https://images.unsplash.com/photo-1499996860823-5214fcc65f8f?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1499996860823-5214fcc65f8f?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1499996860823-5214fcc65f8f?w=600&q=80',
    title:'Inner Light', meta:'Portrait · f/2 · 1/2000s · ISO 100', cat:'portrait', aspectH:110
  },
  {
    src:'https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1200&q=85',
    th:'https://images.unsplash.com/photo-1486325212027-8081e485255e?w=160&q=70',
    grid:'https://images.unsplash.com/photo-1486325212027-8081e485255e?w=600&q=80',
    title:'Steel & Glass', meta:'Urban · f/8 · 1/500s · ISO 200', cat:'urban', aspectH:75
  }
];

let cur=0, filt=[...photos], activeF='all';
const gal=document.getElementById('gal');
const lb=document.getElementById('lb');
const lbImg=document.getElementById('lb-img');
const lbCT=document.getElementById('lb-ctitle');
const lbCM=document.getElementById('lb-cmeta');
const lbStrip=document.getElementById('lb-strip');
const lbCount=document.getElementById('lb-count');

function buildGallery(){
  gal.innerHTML='';
  filt = activeF==='all' ? photos : photos.filter(p=>p.cat===activeF);
  filt.forEach((p,i)=>{
    const d=document.createElement('div');
    d.className='card';
    d.innerHTML=`
      <img class="card-img" src="${p.grid}" alt="${p.title}" style="width:100%;display:block;aspect-ratio:auto" loading="lazy">
      <div class="card-overlay">
        <div class="card-title">${p.title}</div>
        <div class="card-meta">${p.meta}</div>
      </div>
      <div class="expand-ic">
        <svg viewBox="0 0 12 12"><path d="M1 1h4v1H2v3H1V1zm6 0h4v4h-1V2H7V1zM1 7h1v3h3v1H1V7zm10 0v4H7v-1h3V7h1z"/></svg>
      </div>`;
    d.addEventListener('click',()=>openLB(i));
    gal.appendChild(d);
    setTimeout(()=>d.classList.add('visible'),i*75+40);
  });
}

function buildStrip(){
  lbStrip.innerHTML='';
  filt.forEach((p,i)=>{
    const t=document.createElement('img');
    t.className='lb-th'+(i===cur?' active':'');
    t.src=p.th; t.alt=p.title;
    t.addEventListener('click',e=>{e.stopPropagation();goTo(i)});
    lbStrip.appendChild(t);
  });
}

function updateLB(){
  const p=filt[cur];
  lbImg.style.opacity='0';
  lbImg.style.transform='scale(.97)';
  setTimeout(()=>{
    lbImg.src=p.src;
    lbImg.alt=p.title;
    lbImg.style.transition='opacity .35s,transform .35s';
    lbImg.style.opacity='1';
    lbImg.style.transform='scale(1)';
  },110);
  lbCT.textContent=p.title;
  lbCM.textContent=p.meta;
  lbCount.textContent=(cur+1)+' / '+filt.length;
  lbStrip.querySelectorAll('.lb-th').forEach((t,i)=>t.classList.toggle('active',i===cur));
  const th=lbStrip.querySelectorAll('.lb-th')[cur];
  if(th) th.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
}

function openLB(i){cur=i;buildStrip();updateLB();lb.classList.add('open');document.body.style.overflow='hidden'}
function closeLB(){lb.classList.remove('open');document.body.style.overflow=''}
function goTo(i){cur=((i%filt.length)+filt.length)%filt.length;updateLB()}

document.getElementById('lb-prev').addEventListener('click',e=>{e.stopPropagation();goTo(cur-1)});
document.getElementById('lb-next').addEventListener('click',e=>{e.stopPropagation();goTo(cur+1)});
document.getElementById('lb-close').addEventListener('click',closeLB);
document.getElementById('lb-back').addEventListener('click',closeLB);

document.addEventListener('keydown',e=>{
  if(!lb.classList.contains('open'))return;
  if(e.key==='ArrowRight')goTo(cur+1);
  if(e.key==='ArrowLeft')goTo(cur-1);
  if(e.key==='Escape')closeLB();
});

// Touch swipe
let tx=0;
lb.addEventListener('touchstart',e=>tx=e.touches[0].clientX,{passive:true});
lb.addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-tx;
  if(Math.abs(dx)>50){goTo(dx<0?cur+1:cur-1)}
},{passive:true});

document.querySelectorAll('.fbtn').forEach(b=>{
  b.addEventListener('click',()=>{
    document.querySelectorAll('.fbtn').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    activeF=b.dataset.f;
    buildGallery();
  });
});

buildGallery();
</script>
