<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luxury Style Store</title>

<style>
:root{
    --primary:#c59d5f;
    --dark:#111;
    --light:#fff;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:linear-gradient(-45deg,#141414,#1f1f1f,#111,#1a1a1a);
    background-size:400% 400%;
    animation:bgMove 12s ease infinite;
    color:var(--light);
}

@keyframes bgMove{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

header{
    text-align:center;
    padding:25px;
    background:#000;
}

nav{
    display:flex;
    justify-content:center;
    gap:20px;
    padding:15px;
    background:rgba(255,255,255,0.05);
    backdrop-filter:blur(10px);
    position:sticky;
    top:0;
    z-index:100;
}

nav a{
    color:white;
    text-decoration:none;
    font-weight:600;
}

.search-box{
    text-align:center;
    margin:20px;
}

.search-box input{
    padding:10px 20px;
    width:300px;
    border-radius:25px;
    border:none;
}

.section{
    padding:60px 8%;
}

.section h2{
    margin-bottom:40px;
    border-left:4px solid var(--primary);
    padding-left:10px;
}

.products{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:30px;
}

.card{
    background:#1e1e1e;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 10px 25px rgba(0,0,0,0.5);
    transition:0.4s;
}

.card:hover{
    transform:translateY(-10px) scale(1.03);
}

.card img{
    width:100%;
    height:220px;
    object-fit:cover;
    transition:0.4s;
}

.card:hover img{
    transform:scale(1.1);
}

.card-content{
    padding:15px;
    text-align:center;
}

.price{
    color:var(--primary);
    font-weight:bold;
    margin:10px 0;
}

button{
    padding:8px 18px;
    border:none;
    border-radius:25px;
    background:var(--primary);
    cursor:pointer;
}

footer{
    text-align:center;
    padding:20px;
    background:#000;
    margin-top:40px;
}
</style>
</head>

<body>

<header>
<h1>Luxury Style Store</h1>
<p>Owned by Harsh Ghaoghave & Aryan Shegaonkar</p>
</header>

<nav>
<a href="#men">Men</a>
<a href="#women">Women</a>
<a href="#kids">Kids</a>
<a href="#cosmetics">Cosmetics</a>
<a href="#accessories">Accessories</a>
</nav>

<div class="search-box">
<input type="text" id="search" placeholder="Search products...">
</div>

<!-- MEN -->
<section class="section" id="men">
<h2>Men</h2>
<div class="products">
<div class="card"><img src="https://source.unsplash.com/400x400/?men,leather,jacket"><div class="card-content"><h4>Leather Jacket</h4><p class="price">₹4,999</p><button onclick="addToCart('Leather Jacket',4999)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?men,sneakers"><div class="card-content"><h4>Sneakers</h4><p class="price">₹3,299</p><button onclick="addToCart('Sneakers',3299)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?men,luxury,watch"><div class="card-content"><h4>Luxury Watch</h4><p class="price">₹6,499</p><button onclick="addToCart('Luxury Watch',6499)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?men,formal,suit"><div class="card-content"><h4>Formal Suit</h4><p class="price">₹8,999</p><button onclick="addToCart('Formal Suit',8999)">Add</button></div></div>
</div>
</section>

<!-- WOMEN -->
<section class="section" id="women">
<h2>Women</h2>
<div class="products">
<div class="card"><img src="https://source.unsplash.com/400x400/?women,evening,dress"><div class="card-content"><h4>Evening Dress</h4><p class="price">₹3,999</p><button onclick="addToCart('Evening Dress',3999)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?women,handbag"><div class="card-content"><h4>Handbag</h4><p class="price">₹2,499</p><button onclick="addToCart('Handbag',2499)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?women,high,heels"><div class="card-content"><h4>High Heels</h4><p class="price">₹2,999</p><button onclick="addToCart('High Heels',2999)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?women,sunglasses,fashion"><div class="card-content"><h4>Sunglasses</h4><p class="price">₹1,899</p><button onclick="addToCart('Sunglasses',1899)">Add</button></div></div>
</div>
</section>

<!-- KIDS -->
<section class="section" id="kids">
<h2>Kids</h2>
<div class="products">
<div class="card"><img src="https://source.unsplash.com/400x400/?kids,tshirt"><div class="card-content"><h4>Kids T-shirt</h4><p class="price">₹999</p><button onclick="addToCart('Kids T-shirt',999)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?kids,shoes"><div class="card-content"><h4>Kids Shoes</h4><p class="price">₹1,499</p><button onclick="addToCart('Kids Shoes',1499)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?kids,jacket"><div class="card-content"><h4>Kids Jacket</h4><p class="price">₹1,999</p><button onclick="addToCart('Kids Jacket',1999)">Add</button></div></div>
</div>
</section>

<!-- COSMETICS -->
<section class="section" id="cosmetics">
<h2>Cosmetics</h2>
<div class="products">
<div class="card"><img src="https://source.unsplash.com/400x400/?lipstick"><div class="card-content"><h4>Lipstick</h4><p class="price">₹999</p><button onclick="addToCart('Lipstick',999)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?perfume"><div class="card-content"><h4>Perfume</h4><p class="price">₹3,499</p><button onclick="addToCart('Perfume',3499)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?skincare"><div class="card-content"><h4>Skincare Set</h4><p class="price">₹2,799</p><button onclick="addToCart('Skincare Set',2799)">Add</button></div></div>
</div>
</section>

<!-- ACCESSORIES -->
<section class="section" id="accessories">
<h2>Accessories</h2>
<div class="products">
<div class="card"><img src="https://source.unsplash.com/400x400/?leather,belt"><div class="card-content"><h4>Leather Belt</h4><p class="price">₹1,299</p><button onclick="addToCart('Leather Belt',1299)">Add</button></div></div>
<div class="card"><img src="https://source.unsplash.com/400x400/?fashion,cap"><div class="card-content"><h4>Cap</h4><p class="price">₹799</p><button onclick="addToCart('Cap',799)">Add</button></div></div>
</div>
</section>

<footer>
© 2026 Luxury Style Store | Designed & Owned by Harsh Ghaoghave & Aryan Shegaonkar
</footer>

<script>
let total=0;
function addToCart(name,price){
    total+=price;
    alert(name+" added to cart | Total: ₹"+total);
}

document.getElementById("search").addEventListener("keyup",function(){
    let value=this.value.toLowerCase();
    document.querySelectorAll(".card").forEach(card=>{
        card.style.display=card.innerText.toLowerCase().includes(value)?"block":"none";
    });
});
</script>

</body>
</html>
