<!DOCTYPE html>
<html>
<head>
<title>Harsh Ghaoghave & Aryan Shegaokar | Travel World</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>

/* ===== GLOBAL ===== */
html {
    scroll-behavior: smooth;
}

body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background-color: #000;
    color: white;
}

/* ===== NAVBAR ===== */
nav {
    position: fixed;
    top: 0;
    width: 100%;
    background: rgba(0,0,0,0.8);
    padding: 15px;
    text-align: center;
    z-index: 1000;
}

nav a {
    color: white;
    text-decoration: none;
    margin: 15px;
    padding: 8px 15px;
    border: 2px solid white;
    transition: 0.3s;
}

nav a:hover {
    background: white;
    color: black;
}

/* ===== HERO SECTION ===== */
.hero {
    height: 100vh;
    background: url("https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1600&q=80") no-repeat center;
    background-size: cover;
    text-align: center;
    padding-top: 250px;
}

.hero h1 {
    font-size: 50px;
}

/* ===== SECTION ===== */
.section {
    padding: 80px 10%;
    text-align: center;
}

/* ===== CARDS ===== */
.card {
    background: rgba(255,255,255,0.1);
    padding: 30px;
    margin: 30px auto;
    width: 80%;
    border-radius: 10px;
    transition: 0.3s;
}

.card:hover {
    background: rgba(255,255,255,0.2);
}

.card img {
    width: 100%;
    height: 350px;
    object-fit: cover;
}

/* ===== DESTINATIONS ===== */
.destinations img {
    width: 30%;
    margin: 10px;
    transition: 0.3s;
}

.destinations img:hover {
    transform: scale(1.05);
}

/* ===== SLIDER ===== */
.slider img {
    width: 80%;
    height: 400px;
    object-fit: cover;
}

/* ===== GALLERY ===== */
.gallery img {
    width: 30%;
    margin: 10px;
    transition: 0.3s;
}

.gallery img:hover {
    transform: scale(1.1);
}

/* ===== CONTACT ===== */
input, textarea {
    width: 60%;
    padding: 10px;
    margin: 10px;
    border: none;
}

button {
    padding: 10px 20px;
    cursor: pointer;
}

/* ===== FOOTER ===== */
footer {
    background: #111;
    text-align: center;
    padding: 20px;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
    .destinations img,
    .gallery img {
        width: 80%;
    }
    .card {
        width: 95%;
    }
}

</style>
</head>

<body>

<!-- NAVBAR -->
<nav>
<a href="#home">Home</a>
<a href="#harsh">Harsh</a>
<a href="#aryan">Aryan</a>
<a href="#gallery">Gallery</a>
<a href="#contact">Contact</a>
</nav>

<!-- HERO -->
<div id="home" class="hero">
<h1>Harsh Ghaoghave & Aryan Shegaokar</h1>
<p>Exploring The World Together</p>
</div>

<!-- DESTINATIONS -->
<div class="section">
<h2>Featured Destinations</h2>
<div class="destinations">
<img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=800&q=80">
<img src="https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?auto=format&fit=crop&w=800&q=80">
<img src="https://images.unsplash.com/photo-1470770841072-f978cf4d019e?auto=format&fit=crop&w=800&q=80">
</div>
</div>

<!-- SLIDER -->
<div class="section">
<h2>Travel Moments</h2>
<div class="slider">
<img id="slide" src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80">
</div>
</div>

<!-- HARSH -->
<div id="harsh" class="section">
<h2>Harsh Ghaoghave's Travel Stories</h2>
<div class="card">
<img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80">
<p>Adventure lover exploring mountains and hidden gems.</p>
<a href="#aryan" style="color:yellow;">Visit Aryan's Section</a>
</div>
</div>

<!-- ARYAN -->
<div id="aryan" class="section">
<h2>Aryan Shegaokar's Travel Diaries</h2>
<div class="card">
<img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?auto=format&fit=crop&w=1200&q=80">
<p>City explorer capturing culture and experiences.</p>
<a href="#harsh" style="color:yellow;">Visit Harsh's Section</a>
</div>
</div>

<!-- GALLERY -->
<div id="gallery" class="section gallery">
<h2>Gallery</h2>
<img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?auto=format&fit=crop&w=800&q=80">
<img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=800&q=80">
<img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=800&q=80">
</div>

<!-- CONTACT -->
<div id="contact" class="section">
<h2>Contact Us</h2>
<input type="text" placeholder="Your Name"><br>
<input type="email" placeholder="Your Email"><br>
<textarea rows="5" placeholder="Message"></textarea><br>
<button>Send Message</button>
</div>

<footer>
© 2026 Harsh Ghaoghave & Aryan Shegaokar
</footer>

<!-- WORKING SLIDER SCRIPT -->
<script>
var images = [
"https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80",
"https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?auto=format&fit=crop&w=1200&q=80",
"https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1200&q=80"
];

var i = 0;
setInterval(function(){
    i++;
    if(i >= images.length){ i = 0; }
    document.getElementById("slide").src = images[i];
},3000);
</script>

</body>
</html>
